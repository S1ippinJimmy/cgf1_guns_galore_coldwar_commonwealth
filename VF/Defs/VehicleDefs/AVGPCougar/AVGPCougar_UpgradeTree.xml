<?xml version="1.0" encoding="utf-8" ?>

<Defs>
	<Vehicles.UpgradeTreeDef>
		<defName>CGF1_MWP_Vehicle_AVGPCougar_UpgradeTree</defName>
		 
		<nodes>
		
			<!-- Main Guns -->
			
			<li>
				<key>MainTurret_Removed</key>
				<label>Remove main turret</label>
				<description>Remove the main turret and its armament from the vehicle. Reduces mass.</description>
				
				<icon>CGF1/Vehicle/AVGP/AVGPCougar_east</icon>
				
				<work>2500</work>
				
				<disableIfUpgradeNodesEnabled>
					<li>MainTurret_90mmCockerillMk3MA1</li>
					<li>MainTurret_30mmL21RARDEN</li>
					<li>Pintle_C5A1</li>
					<li>Pintle_C6</li>
					<li>Pintle_M2HB</li>
				</disableIfUpgradeNodesEnabled>
				
				<gridCoordinate>(27, 1)</gridCoordinate>
				<drawSize>(50, 50)</drawSize>
				
				<!--<prerequisiteNodes>
					<li>MainTurret_Removed</li>
				</prerequisiteNodes>-->
				
				<upgrades>
					<li Class = "Vehicles.TurretUpgrade">
						<removeTurrets>
							<li>mainTurret</li>
							<li>coaxialMG</li>
						</removeTurrets>
					</li>
					<li MayRequire="OskarPotocki.VanillaVehiclesExpanded" Class="Vehicles.CompUpgrade">
						<deactivate>
							<li Class="VanillaVehiclesExpanded.CompProperties_ReloadableWithVerbs" />
						</deactivate>
					</li>
					<li Class = "Vehicles.StatUpgrade">
						<vehicleStats>
							<li>
								<def>Mass</def>
								<value>-75</value>
							</li>
						</vehicleStats>
					</li>
				</upgrades>
			</li>
			<li>
				<key>MainTurret_90mmCockerillMk3MA1</key>
				<label>90mm Cockerill Mk3 M-A1</label>
				<description>Replace the main gun with a low-velocity, 90mm Cockerill Mk3 MA-1 infantry support cannon (with coaxial C5A1 machine gun.) Increases range and area of effect at the cost of weight and reload speed.\n\nFictional upgrade. Though not historically mounted to the AVGP, the 90mm Cockerill was able to use the FV101 Scorpion's same turret design (which the AVGP Cougar already used), making integration plausible.</description>
				
				<icon>CGF1/Vehicle/FV101Scorpion/90mm_CockerillMk3MA1_Icon</icon>
				
				<work>15000</work>
				
				<disableIfUpgradeNodesEnabled>
					<li>MainTurret_Removed</li>
					<li>MainTurret_30mmL21RARDEN</li>
					<li>Pintle_C5A1</li> <!-- Disabled one-way due to a VF bug -->
					<li>Pintle_C6</li>
					<li>Pintle_M2HB</li>
				</disableIfUpgradeNodesEnabled>
				
				<gridCoordinate>(27, 4)</gridCoordinate>
				<drawSize>(50, 50)</drawSize>
				
				<upgrades>
					<li Class="Vehicles.TurretUpgrade">
						<turrets>
							<li>
								<turretDef>CGF1_MWP_Vehicle_TurretGun_90mm_CockerillMk3MA1_AVGP</turretDef>
								
								<renderProperties>
									<north>(-0.1, -0.3)</north>
									<south>(0.1, 1.15)</south>
									<east>(-1.12, 0.82)</east>
								</renderProperties>
								<drawLayer>2</drawLayer>

								<gizmoLabel>90mm Mk3 M-A1</gizmoLabel>
								
								<angleRestricted/>
								<aimPieOffset>(0, 2.4)</aimPieOffset>
								
								<key>mainTurret</key>
							</li>
							<li>
								<turretDef>CGF1_MWP_Vehicle_TurretGun_C5A1_Coaxial_</turretDef>
								
								<renderProperties>
									<north>(-0.21,0.85)</north>
								</renderProperties>
								<drawLayer>3</drawLayer>
								
								<gizmoLabel>C5A1</gizmoLabel>
								
								<angleRestricted>(345, 15)</angleRestricted>
								<aimPieOffset>(0, 0.05</aimPieOffset>
								
								<key>coaxialMG</key>
								<parentKey>mainTurret</parentKey>
							</li>
						</turrets>
						<removeTurrets>
							<li>mainTurret</li>
							<li>coaxialMG</li>
						</removeTurrets>
					</li>
					<li Class = "Vehicles.StatUpgrade">
						<vehicleStats>
							<li>
								<def>Mass</def>
								<value>80</value>
							</li>
						</vehicleStats>
					</li>
				</upgrades>
				
				<ingredients>
					<Steel>100</Steel>
					<ComponentIndustrial>2</ComponentIndustrial>
				</ingredients>
			</li>
			<li>
				<key>MainTurret_30mmL21RARDEN</key>
				<label>30mm L21 RARDEN</label>
				<description>Replace the main turret and its armament with a 30mm L21 RARDEN autocannon (and coaxial C5A1 machine gun.)\n\nFictional upgrade.</description>
				
				<icon>CGF1/Vehicle/FV107Scimitar/30mm_RARDEN_FV107_Icon</icon>
				
				<work>17500</work>
				
				<disableIfUpgradeNodesEnabled>
					<li>MainTurret_Removed</li>
					<li>MainTurret_90mmCockerillMk3MA1</li>
					<li>Pintle_C5A1</li> <!-- Disabled one-way due to a VF bug -->
					<li>Pintle_C6</li>
					<li>Pintle_M2HB</li>
				</disableIfUpgradeNodesEnabled>
				
				<gridCoordinate>(27, 7)</gridCoordinate>
				<drawSize>(50, 50)</drawSize>
				
				<upgrades>
					<li Class="Vehicles.TurretUpgrade">
						<turrets>
							<li>
								<turretDef>CGF1_MWP_Vehicle_TurretGun_30mmRARDEN_AVGP</turretDef>
								
								<renderProperties>
									<north>(-0.1, -0.3)</north>
									<south>(0.1, 1.15)</south>
									<east>(-1.12, 0.82)</east>
								</renderProperties>
								<drawLayer>2</drawLayer>

								<gizmoLabel>30mm L21 RARDEN</gizmoLabel>
								
								<angleRestricted/>
								<aimPieOffset>(0, 2.4)</aimPieOffset>
								
								<key>mainTurret</key>
							</li>
							<li>
								<turretDef>CGF1_MWP_Vehicle_TurretGun_C5A1_Coaxial_</turretDef>
								
								<renderProperties>
									<north>(-0.21,0.85)</north>
								</renderProperties>
								<drawLayer>3</drawLayer>
								
								<gizmoLabel>C5A1</gizmoLabel>
								
								<angleRestricted>(345, 15)</angleRestricted>
								<aimPieOffset>(0, 0.05</aimPieOffset>
								
								<key>coaxialMG</key>
								<parentKey>mainTurret</parentKey>
							</li>
						</turrets>
						<removeTurrets>
							<li>mainTurret</li>
							<li>coaxialMG</li>
						</removeTurrets>
					</li>
					<li Class = "Vehicles.StatUpgrade">
						<vehicleStats>
							<li>
								<def>Mass</def>
								<value>80</value>
							</li>
						</vehicleStats>
					</li>
				</upgrades>
				
				<ingredients>
					<Steel>100</Steel>
					<ComponentIndustrial>2</ComponentIndustrial>
				</ingredients>
			</li>
			
			<!-- Roof Guns -->
			
			<li>
				<key>Pintle_C5A1</key>
				<label>Pintle: C5A1</label>
				<description>Install a C5A1 MMG on the roof of the vehicle. Requires steel to refurbish.</description>
				
				<icon>CGF1/Vehicle/Turret/Coax/Browning_M1919A4</icon>
				
				<work>7000</work>
				
				<disableIfUpgradeNodesEnabled>
					<li>MainTurret_Removed</li>
					<li>Pintle_C6</li>
					<li>Pintle_M2HB</li>
				</disableIfUpgradeNodesEnabled>
				
				<gridCoordinate>(30, 1)</gridCoordinate>
				<drawSize>(50, 50)</drawSize>
				
				<upgrades>
					<li Class="Vehicles.TurretUpgrade">
						<turrets>
							<li>
								<turretDef>CGF1_MWP_Vehicle_TurretGun_C5A1_Medium_</turretDef>
								
								<renderProperties>
									<north>(-0.2, 0.5)</north>
								</renderProperties>
								<drawLayer>3</drawLayer>

								<gizmoLabel>C5A1</gizmoLabel>
								
								<angleRestricted/>
								<aimPieOffset>(0, 0.5)</aimPieOffset>
								<!--<defaultAngleRotated>270</defaultAngleRotated>-->
								
								<key>commanderTurret</key>
								<parentKey>mainTurret</parentKey>
							</li>
						</turrets>
					</li>
				</upgrades>

				<ingredients>
					<Steel>85</Steel>
					<ComponentIndustrial>2</ComponentIndustrial>
				</ingredients>
			</li>
			<li>
				<key>Pintle_C6</key>
				<label>Pintle: C6</label>
				<description>Install a C6 GPMG on the roof of the vehicle. Requires steel to refurbish.</description>
				
				<icon>CGF1/Vehicle/Turret/Coax/C6</icon>
				
				<work>7000</work>
				
				<disableIfUpgradeNodesEnabled>
					<li>MainTurret_Removed</li>
					<li>Pintle_C5A1</li>
					<li>Pintle_M2HB</li>
				</disableIfUpgradeNodesEnabled>
				
				<gridCoordinate>(30, 4)</gridCoordinate>
				<drawSize>(50, 50)</drawSize>
				
				<upgrades>
					<li Class="Vehicles.TurretUpgrade">
						<turrets>
							<li>
								<turretDef>CGF1_MWP_Vehicle_TurretGun_L7A1_Small_</turretDef>
								
								<renderProperties>
									<north>(-0.3, 0.2)</north>
								</renderProperties>
								<drawLayer>3</drawLayer>

								<gizmoLabel>C6</gizmoLabel>
								
								<angleRestricted/>
								<aimPieOffset>(0, 0.5)</aimPieOffset>
								<!--<defaultAngleRotated>270</defaultAngleRotated>-->
								
								<key>commanderTurret</key>
								<parentKey>mainTurret</parentKey>
							</li>
						</turrets>
					</li>
				</upgrades>

				<ingredients>
					<Steel>85</Steel>
					<ComponentIndustrial>2</ComponentIndustrial>
				</ingredients>
			</li>
			<li>
				<key>Pintle_M2HB</key>
				<label>Pintle: M2HB</label>
				<description>Install an M2HB HMG on the roof of the vehicle. Requires steel to refurbish.</description>
				
				<icon>CGF1/Vehicle/Turret/Coax/Browning_M2HB</icon>
				
				<work>8000</work>
				
				<disableIfUpgradeNodesEnabled>
					<li>MainTurret_Removed</li>
					<li>Pintle_C5A1</li>
					<li>Pintle_C6</li>
				</disableIfUpgradeNodesEnabled>
				
				<gridCoordinate>(30, 7)</gridCoordinate>
				<drawSize>(50, 50)</drawSize>
				
				<upgrades>
					<li Class="Vehicles.TurretUpgrade">
						<turrets>
							<li>
								<turretDef>CGF1_MWP_Vehicle_TurretGun_M2HB_Small_</turretDef>
								
								<renderProperties>
									<north>(-0.3, 0.2)</north>
								</renderProperties>
								<drawLayer>3</drawLayer>

								<gizmoLabel>M2HB</gizmoLabel>
								
								<angleRestricted/>
								<aimPieOffset>(0, 0.9)</aimPieOffset>
								
								<key>commanderTurret</key>
								<parentKey>mainTurret</parentKey>
							</li>
						</turrets>
					</li>
				</upgrades>

				<ingredients>
					<Steel>100</Steel>
					<ComponentIndustrial>3</ComponentIndustrial>
				</ingredients>
			</li>	
		</nodes>
	</Vehicles.UpgradeTreeDef>
</Defs>
