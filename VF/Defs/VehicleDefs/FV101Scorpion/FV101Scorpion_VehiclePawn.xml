<?xml version="1.0" encoding="utf-8" ?>

<Defs>	
	<Vehicles.VehicleDef ParentName="CGF1_MWP_Vehicle_Base_CVRT">
		<defName>CGF1_MWP_Vehicle_FV101Scorpion</defName>
		<label>FV101 Scorpion</label>
		<description>A tracked, armored British reconnaissance vehicle/light tank based on the CVR(T) platform.\n\n&lt;color=#bb8f04&gt;Crew:&lt;/color&gt; Driver x1, Gunnner x1, Commander x1\n&lt;color=#bb8f04&gt;Fuel type:&lt;/color&gt; Chemfuel</description>
		
		<graphicData>
			<texPath>CGF1/Vehicle/FV101Scorpion/FV101Scorpion</texPath>
			<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(2.5, 5.0)</drawSize>
			<color>(215, 200, 175)</color>
			<colorTwo>(56, 55, 50)</colorTwo>
			<colorThree>(100, 69, 59)</colorThree>
		</graphicData>
		
		<buildDef>CGF1_MWP_Vehicle_FV101Scorpion_Blueprint</buildDef>
		
		<size>(3, 5)</size>
		
		<statBases>
			<MarketValue>5000</MarketValue>
			<PackRadius MayRequire="OskarPotocki.VanillaVehiclesExpanded">6.9</PackRadius>
		</statBases>
		
		<vehicleStats>
			<Mass>505</Mass>
			<MoveSpeed>6.8</MoveSpeed>
			<CargoCapacity>165</CargoCapacity>
			<RepairRate>0.3</RepairRate>
			<AccelerationRate MayRequire="OskarPotocki.VanillaVehiclesExpanded">0.06</AccelerationRate>
		</vehicleStats>
		
		<race>
			<baseBodySize>4.5</baseBodySize>
		</race>
		
		<properties>
			<winterCostMultiplier>2.125</winterCostMultiplier>
			<worldSpeedMultiplier>1.05</worldSpeedMultiplier>
			<visibilityWeight>4.5</visibilityWeight>

			<vehicleJobLimitations>
				<li>(RepairVehicle, 3)</li>
			</vehicleJobLimitations>
			
			<roles>
				<li>
					<key>driver</key>
					<label>Driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
					
					<hitbox>
						<cells>
							<li>(0, 1)</li>
						</cells>
					</hitbox>
				</li>
				<li>
					<key>gunner</key>
					<label>Gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>		
					
					<handlingTypes>Turret</handlingTypes>
					
					<turretIds>
						<li>mainTurret</li>
						<li>coaxialMG</li>
					</turretIds>
					
					<hitbox>
						<cells>
							<li>(-1, -1)</li>
						</cells>
					</hitbox>
				</li>
				<li>
					<key>commander</key>
					<label>Commander</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>Turret</handlingTypes>
					
					<turretIds>
						<li>commanderTurret</li>
					</turretIds>
					
					<hitbox>
						<cells>
							<li>(0, 0)</li>
						</cells>
					</hitbox>
				</li>
			</roles>
		</properties>
		
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>28</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>80</fuelCapacity>
			</li>
			<li Class = "Vehicles.CompProperties_UpgradeTree">
				<def>CGF1_MWP_Vehicle_FV101Scorpion_UpgradeTree</def>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<turrets>
					<li>
						<turretDef>CGF1_MWP_Vehicle_TurretGun_76mm_L23A1</turretDef>
						
						<renderProperties>
							<north>(0, -0.3)</north>
							<south>(0, 1.1)</south>
							<east>(-1.05, 0.58)</east>
						</renderProperties>
						<drawLayer>2</drawLayer>
						
						<gizmoLabel>76mm L23A1</gizmoLabel>
						
						<angleRestricted/>
						<aimPieOffset>(0, 2)</aimPieOffset>
						
						<key>mainTurret</key>
					</li>
					<li>
						<turretDef>CGF1_MWP_Vehicle_TurretGun_L43A1_RangingGun_Coaxial_</turretDef>
						
						<renderProperties>
							<north>(-0.21,0.85)</north>
						</renderProperties>
						<drawLayer>3</drawLayer>
						
						<gizmoLabel>L43A1 Ranging Gun</gizmoLabel>
						
						<angleRestricted>(345, 15)</angleRestricted>
						<aimPieOffset>(0, 0.05</aimPieOffset>
						
						<key>coaxialMG</key>
						<parentKey>mainTurret</parentKey>
					</li>
				</turrets>
			</li>
			<li MayRequire="OskarPotocki.VanillaVehiclesExpanded" Class="VanillaVehiclesExpanded.CompProperties_ReloadableWithVerbs">
				<maxCharges>4</maxCharges>
				<ammoDef>Chemfuel</ammoDef>
				<ammoCountToRefill>10</ammoCountToRefill>
				<soundReload>Standard_Reload</soundReload>
				<hotKey>Misc4</hotKey>
				<chargeNoun>smokepop</chargeNoun>
				<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
				<verbs>
					<li>
						<verbClass>VanillaVehiclesExpanded.Verb_Smokepop</verbClass>
						<label>pop smoke</label>
						<violent>false</violent>
						<hasStandardCommand>true</hasStandardCommand>
						<commandIcon>CGF1/Vehicle/Upgrade/SmokePop</commandIcon>
						<targetable>false</targetable>
						<nonInterruptingSelfCast>true</nonInterruptingSelfCast>
						<onlyManualCast>true</onlyManualCast>
					</li>
				</verbs>
				<commandDescriptions>
					<li>A defensive smokescreen. When activated, it will release a cloud of smoke, obscuring incoming shots and preventing turrets from locking on. Has four charges and will require a chemfuel reload after they are spent. Right click to reload.</li>
				</commandDescriptions>
			</li>
		</comps>
	</Vehicles.VehicleDef>
</Defs>