						<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
						<drawSize>(3.33, 5.55)</drawSize>
						<!--<drawOffsetNorth>(0, 0, 1.3)</drawOffsetNorth>
						<drawOffsetEast>(0.55, 0, 0.5)</drawOffsetEast>
						<drawOffsetSouth>(0, 0, 0.125)</drawOffsetSouth>
						<drawOffsetWest>(-0.55, 0, 0.5)</drawOffsetWest>-->
						<layer>11</layer>
						<shaderType>CutoutComplexPattern</shaderType>
					</graphicData>
				</li>
			</graphicOverlays>
		</drawProperties>
		
		<properties>	
			<roles>
				<li>
					<key>driver</key>
					<label>Driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
					
					<hitbox>
						<cells>
							<li>(1, 1)</li>
						</cells>
					</hitbox>
					
					<pawnRenderer>
						<layer>0</layer>
						<drawOffsetNorth>(0.37, 0, 0.4)</drawOffsetNorth>
						<drawOffsetSouth>(-0.38, 0, 0.1)</drawOffsetSouth>
						<drawOffsetEast>(0.37, 0, 0.1)</drawOffsetEast>
					</pawnRenderer>
				</li>
				<li>
					<key>passenger</key>
					<label>Passenger</label>
					<slots>1</slots>
					
					<hitbox>
						<cells>
							<li>(0, 1)</li>
						</cells>
					</hitbox>
					
					<pawnRenderer>
						<layer>0</layer>
						<drawOffsetNorth>(-0.37, 0, 0.4)</drawOffsetNorth>
						<drawOffsetSouth>(0.38, 0, 0.1)</drawOffsetSouth>
						<drawOffsetEast>(0.37, 0, 0.67)</drawOffsetEast>
					</pawnRenderer>
				</li>
			</roles>
		</properties>
		
