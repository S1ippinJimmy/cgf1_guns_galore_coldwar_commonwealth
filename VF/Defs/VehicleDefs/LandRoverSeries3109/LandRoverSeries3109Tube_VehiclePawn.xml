				<fuelConsumptionRate>20.5</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>120</fuelCapacity>
			</li>
			<li Class = "Vehicles.CompProperties_UpgradeTree">
				<def>CGF1_MWP_Vehicle_LandRoverSeries3109Tube_UpgradeTree</def>
			</li>
