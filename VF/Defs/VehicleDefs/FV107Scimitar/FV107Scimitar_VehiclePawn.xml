<?xml version="1.0" encoding="utf-8" ?>

<Defs>	
	<Vehicles.VehicleDef ParentName="CGF1_MWP_Vehicle_Base_CVRT">
		<defName>CGF1_MWP_Vehicle_FV107Scimitar</defName>
		<label>FV107 Scimitar</label>
		<description>A tracked, armored British reconnaissance vehicle based on the CVR(T) platform.\n\n&lt;color=#bb8f04&gt;Crew:&lt;/color&gt; Driver x1, Gunnner x1, Commander x1\n&lt;color=#bb8f04&gt;Fuel type:&lt;/color&gt; Chemfuel</description>
		
		<graphicData>
			<texPath>CGF1/Vehicle/FV107Scimitar/FV107Scimitar</texPath>
			<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(2.4, 4.8)</drawSize>
			<color>(215, 200, 175)</color>
			<colorTwo>(56, 55, 50)</colorTwo>
			<colorThree>(100, 69, 59)</colorThree>
		</graphicData>
		
		<buildDef>CGF1_MWP_Vehicle_FV107Scimitar_Blueprint</buildDef>
		
		<size>(3, 5)</size>
		
		<statBases>
			<MarketValue>5000</MarketValue>
			<PackRadius MayRequire="OskarPotocki.VanillaVehiclesExpanded">6.9</PackRadius>
		</statBases>
		
		<vehicleStats>
			<Mass>480</Mass>
			<MoveSpeed>6.8</MoveSpeed>
			<CargoCapacity>150</CargoCapacity>
			<RepairRate>0.3</RepairRate>
			<AccelerationRate MayRequire="OskarPotocki.VanillaVehiclesExpanded">0.06</AccelerationRate>
		</vehicleStats>
		
		<race>
			<baseBodySize>4.5</baseBodySize>
		</race>
		
		<properties>
			<winterCostMultiplier>2.125</winterCostMultiplier>
			<worldSpeedMultiplier>1.05</worldSpeedMultiplier>
			<visibilityWeight>4.5</visibilityWeight>

			<vehicleJobLimitations>
				<li>(RepairVehicle, 3)</li>
			</vehicleJobLimitations>
			
			<roles>
				<li>
					<key>driver</key>
					<label>Driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
					
					<hitbox>
						<cells>
							<li>(0, 1)</li>
						</cells>
					</hitbox>
				</li>
				<li>
					<key>gunner</key>
					<label>Gunner</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>		
					
					<handlingTypes>Turret</handlingTypes>
					
					<turretIds>
						<li>mainTurret</li>
						<li>coaxialMG</li>
					</turretIds>
					
					<hitbox>
						<cells>
							<li>(-1, -1)</li>
						</cells>
					</hitbox>
				</li>
				<li>
					<key>commander</key>
					<label>Commander</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>Turret</handlingTypes>
					
					<turretIds>
						<li>commanderTurret</li>
					</turretIds>
					
					<hitbox>
						<cells>
							<li>(0, 0)</li>
						</cells>
					</hitbox>
				</li>
			</roles>
		</properties>
		
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>28</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>80</fuelCapacity>
			</li>
			<li Class = "Vehicles.CompProperties_UpgradeTree">
				<def>CGF1_MWP_Vehicle_FV107Scimitar_UpgradeTree</def>
			</li>
			<li Class="Vehicles.CompProperties_VehicleTurrets">
				<turrets>
					<li>
						<turretDef>CGF1_MWP_Vehicle_TurretGun_30mmRARDEN_FV107</turretDef>
						
						<renderProperties>
							<north>(0, -0.3)</north>
							<south>(0, 1.1)</south>
							<east>(-1.05, 0.51)</east>
						</renderProperties>
						<drawLayer>2</drawLayer>
						
						<gizmoLabel>30mm L21 RARDEN</gizmoLabel>
						
						<angleRestricted/>
						<aimPieOffset>(0, 2)</aimPieOffset>
						
						<key>mainTurret</key>
					</li>
					<li>
						<turretDef>CGF1_MWP_Vehicle_TurretGun_L37A1_Coaxial_</turretDef>
						
						<renderProperties>
							<north>(-0.21,0.85)</north>
						</renderProperties>
						<drawLayer>3</drawLayer>
						
						<gizmoLabel>L37A1</gizmoLabel>
						
						<angleRestricted>(345, 15)</angleRestricted>
						<aimPieOffset>(0, 0.05</aimPieOffset>
						
						<key>coaxialMG</key>
						<parentKey>mainTurret</parentKey>
					</li>
				</turrets>
			</li>
		</comps>
	</Vehicles.VehicleDef>
</Defs>