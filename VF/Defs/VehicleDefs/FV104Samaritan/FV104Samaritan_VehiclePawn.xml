<?xml version="1.0" encoding="utf-8" ?>

<Defs>	
	<Vehicles.VehicleDef ParentName="CGF1_MWP_Vehicle_Base_CVRT">
		<defName>CGF1_MWP_Vehicle_FV104Samaritan</defName>
		<label>FV104 Samaritan</label>
		<description>A tracked, armored British ambulance vehicle based on the CVR(T) platform.\n\n&lt;color=#bb8f04&gt;Crew:&lt;/color&gt; Driver x1, Passenger x6\n&lt;color=#bb8f04&gt;Fuel type:&lt;/color&gt; Chemfuel</description>
		
		<graphicData>
			<texPath>CGF1/Vehicle/FV104Samaritan/FV104Samaritan</texPath>
			<graphicClass>Vehicles.Graphic_Vehicle</graphicClass>
			<shaderType>CutoutComplexPattern</shaderType>
			<drawSize>(3, 6)</drawSize>
			<color>(215, 200, 175)</color>
			<colorTwo>(56, 55, 50)</colorTwo>
			<colorThree>(100, 69, 59)</colorThree>
		</graphicData>
		
		<buildDef>CGF1_MWP_Vehicle_FV104Samaritan_Blueprint</buildDef>
		
		<size>(3, 5)</size>
		
		<statBases>
			<MarketValue>4650</MarketValue>
			<PackRadius MayRequire="OskarPotocki.VanillaVehiclesExpanded">6.9</PackRadius>
		</statBases>
		
		<vehicleStats>
			<Mass>450</Mass>
			<MoveSpeed>6.8</MoveSpeed>
			<CargoCapacity>275</CargoCapacity>
			<RepairRate>0.3</RepairRate>
			<AccelerationRate MayRequire="OskarPotocki.VanillaVehiclesExpanded">0.06</AccelerationRate>
		</vehicleStats>
		
		<race>
			<baseBodySize>4.5</baseBodySize>
		</race>
		
		<properties>
			<winterCostMultiplier>2.125</winterCostMultiplier>
			<worldSpeedMultiplier>1.05</worldSpeedMultiplier>
			<visibilityWeight>4.5</visibilityWeight>

			<vehicleJobLimitations>
				<li>(RepairVehicle, 3)</li>
			</vehicleJobLimitations>
			
			<roles>
				<li>
					<key>driver</key>
					<label>Driver</label>
					<slots>1</slots>
					<slotsToOperate>1</slotsToOperate>
					
					<handlingTypes>
						<li>Movement</li>
					</handlingTypes>
					
					<hitbox>
						<cells>
							<li>(0, 1)</li>
						</cells>
					</hitbox>
				</li>
				<li>
					<key>passenger</key>
					<label>Passenger</label>
					<slots>6</slots>
					
					<hitbox>
						<cells>
							<li>(-1, -1)</li>
							<li>(0, -1)</li>
							<li>(1, -1)</li>
							<li>(-1, -2)</li>
							<li>(0, -2)</li>
							<li>(1, -2)</li>
						</cells>
					</hitbox>
				</li>
			</roles>
		</properties>
		
		<comps>
			<li Class="Vehicles.CompProperties_FueledTravel">
				<fuelType>Chemfuel</fuelType>
				<leakDef>Filth_Fuel</leakDef>
				<fuelConsumptionRate>28</fuelConsumptionRate>
				<fuelConsumptionWorldMultiplier>1</fuelConsumptionWorldMultiplier>
				<fuelCapacity>80</fuelCapacity>
			</li>
			<li Class = "Vehicles.CompProperties_UpgradeTree">
				<def>CGF1_MWP_Vehicle_FV104Samaritan_UpgradeTree</def>
			</li>
		</comps>
	</Vehicles.VehicleDef>
</Defs>